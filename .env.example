# ============================================================
# DFIR Triage Agent — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# The ONLY required key to run the full pipeline is OPENAI_API_KEY.
# GEMINI_API_KEY is optional — the system falls back to TF-IDF embeddings
# automatically if it is missing.
# ============================================================

# --- LLM Model Selection ---
# Supports any OpenRouter model via the openai/ prefix.
# Browse available models at: https://openrouter.ai/models
# Recommended free models: deepseek/deepseek-v4-flash, google/gemma-3-27b-it:free
LOG_ANALYST_MODEL=openai/deepseek/deepseek-v4-flash

# --- OpenRouter API (Required) ---
# Get a free key at: https://openrouter.ai/keys
# The base URL routes through OpenRouter's OpenAI-compatible endpoint.
OPENAI_API_KEY=your-openrouter-api-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1

# --- Google / Gemini API (Optional) ---
# Enables Phase 2 text-embedding-004 for NLP semantic anomaly detection.
# If missing, the pipeline automatically falls back to TF-IDF embeddings.
# Get a free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
